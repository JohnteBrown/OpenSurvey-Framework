{
  "arrow_spacing": {
    "level": "ignore"
  },
  "camel_case_classes": {
    "level": "warn"
  },
  "colon_assignment_spacing": {
    "spacing": {
      "left": 0,
      "right": 1
    }
  },
  "indentation": {
    "value": 2,
    "level": "warn"
  },
  "line_endings": {
    "value": "unix"
  },
  "max_line_length": {
    "value": 120,
    "level": "warn"
  },
  "no_backticks": {
    "level": "error"
  },
  "no_empty_param_list": {
    "level": "error"
  },
  "no_implicit_braces": {
    "level": "ignore"
  },
  "no_implicit_parens": {
    "level": "ignore"
  },
  "no_tabs": {
    "level": "error"
  },
  "space_operators": {
    "level": "warn"
  },
  "trailing_semicolons": {
    "level": "ignore"
  }
}
